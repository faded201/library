# Environment Variables for AETHERIA.AI
# Copy this file to .env.local and fill in your API keys

# Noiz API Key for TTS (get from https://noiz.ai)
REACT_APP_NOIZ_API_KEY=your_noiz_api_key_here

# Free AI Models
REACT_APP_GEMINI_API_KEY=your_gemini_key_here
REACT_APP_GROK_API_KEY=your_grok_key_here  
REACT_APP_MISTRAL_API_KEY=your_mistral_key_here

# Paid AI Models (Lowest Cost Options)
REACT_APP_CLAUDE_API_KEY=your_claude_key_here
REACT_APP_OPENAI_API_KEY=your_openai_key_here
REACT_APP_SONNET_API_KEY=your_sonnet_key_here

# API Base URLs
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_NOIZ_BASE_URL=https://api.noiz.ai
